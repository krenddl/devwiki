@page "/"
@using DevWiki.Client.Models
@using DevWiki.Client.Services
@inject IArticleService ArticleService

<PageTitle>DevWiki - Главная</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-5 mt-4">
    <div>
        <h1 class="text-gradient fw-bold mb-2" style="font-size: 3rem;">База знаний</h1>
        <p class="text-muted fs-5 mb-0">Современная документация и заметки для разработчиков</p>
    </div>
    
    <AuthorizeView>
        <Authorized>
            <a href="/articles/create" class="btn-modern btn-primary-modern text-decoration-none">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Новая статья
            </a>
        </Authorized>
    </AuthorizeView>
</div>

<div class="mb-4 position-relative">
    <svg class="position-absolute text-muted" width="18" height="18" style="left: 1rem; top: 50%; transform: translateY(-50%);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    <input type="text" class="form-control-modern ps-5" placeholder="Поиск по заголовку, содержанию или тегам..." @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
</div>

@if (articles == null)
{
    <div class="row g-4">
        @for (int i = 0; i < 4; i++)
        {
            <div class="col-md-6 d-flex">
                <div class="modern-card d-flex flex-column w-100 p-4">
                    <div class="skeleton skeleton-title"></div>
                    <div class="skeleton skeleton-text short mb-4"></div>
                    <div class="skeleton skeleton-text"></div>
                    <div class="skeleton skeleton-text"></div>
                    <div class="skeleton skeleton-text short mb-4"></div>
                    <div class="mt-auto d-flex gap-2">
                        <div class="skeleton skeleton-text short" style="width: 60px; height: 24px; border-radius: 999px;"></div>
                        <div class="skeleton skeleton-text short" style="width: 80px; height: 24px; border-radius: 999px;"></div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (!articles.Any())
{
    <div class="modern-card text-center py-5">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-muted mb-4"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        <h3 class="mb-3">Пока нет ни одной статьи</h3>
        <p class="text-muted mb-4">
            <AuthorizeView>
                <Authorized>Создай первую запись в базе знаний.</Authorized>
                <NotAuthorized><a href="/login" class="text-white text-decoration-underline">Войди в систему</a>, чтобы написать первую статью.</NotAuthorized>
            </AuthorizeView>
        </p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var article in articles)
        {
            <div class="col-md-6 d-flex">
                <a href="/articles/@article.Id" class="modern-card modern-card-hoverable text-decoration-none d-flex flex-column w-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h4 class="mb-0 text-white">@article.Title</h4>
                    </div>
                    <div class="text-muted small mb-3">
                        @article.CreatedAt.ToString("d MMMM yyyy")
                    </div>
                    
                    <p class="text-muted flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">
                        @article.Content
                    </p>
                    
                    @if (article.Tags != null && article.Tags.Any())
                    {
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            @foreach (var tag in article.Tags.Take(3))
                            {
                                <span class="badge-modern">@tag</span>
                            }
                            @if (article.Tags.Count > 3)
                            {
                                <span class="badge-modern">...</span>
                            }
                        </div>
                    }
                </a>
            </div>
        }
    </div>
}

@code {
    private List<ArticleDto>? articles;
    private string searchTerm = string.Empty;
    private System.Threading.Timer? searchTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadArticles();
    }

    private async Task LoadArticles()
    {
        articles = await ArticleService.GetArticlesAsync(searchTerm);
        StateHasChanged();
    }

    private void HandleSearch()
    {
        searchTimer?.Dispose();
        searchTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(LoadArticles);
        }, null, 500, Timeout.Infinite); // 500ms debounce
    }
}

