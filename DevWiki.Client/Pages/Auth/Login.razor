@page "/login"
@using DevWiki.Client.Models
@using DevWiki.Client.Services
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Вход - DevWiki</PageTitle>

<div class="terminal-window">
    <div class="terminal-header">
        <div class="term-dots">
            <div class="term-dot dot-close"></div>
            <div class="term-dot dot-min"></div>
            <div class="term-dot dot-max"></div>
        </div>
        login — DevWiki-Blazor-WASM (tty2)
    </div>
    
    <div class="terminal-body" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">
        
        <div class="ascii-art text-center mb-4">
            <pre style="margin:0; background:transparent; border:none; padding:0; overflow:hidden; font-family:inherit;">
  _                 _       
 | |               (_)      
 | | ___   __ _ _ __ _ _ __ 
 | |/ _ \ / _` | '__| | '__|
 | | (_) | (_| | |  | | |   
 |_|\___/ \__, |_|  |_|_|   
           __/ |            
          |___/             
            </pre>
        </div>

        <div class="term-form-container">
            <div class="line dim mb-4 text-center">Please enter your credentials to authenticate.</div>

            @if (showError)
            {
                <div class="line error mb-3">[Auth] Error: Неверный логин или пароль</div>
            }

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <div class="line">Username:</div>
                    <InputText id="username" class="term-input" autocomplete="off" spellcheck="false" @bind-Value="loginModel.Username" />
                    <ValidationMessage For="@(() => loginModel.Username)" class="error mt-1" style="font-size: 0.85rem;" />
                </div>

                <div class="mb-3">
                    <div class="line">Password:</div>
                    <InputText type="password" id="password" class="term-input" autocomplete="off" @bind-Value="loginModel.Password" />
                    <ValidationMessage For="@(() => loginModel.Password)" class="error mt-1" style="font-size: 0.85rem;" />
                </div>

                <button type="submit" class="term-btn" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>[Authenticating...]</span>
                    }
                    else
                    {
                        <span>> EXECUTE LOGIN</span>
                    }
                </button>
            </EditForm>
            
            <div class="line dim mt-4 text-center">
                Need an account? <a href="/register" class="blue text-decoration-none" style="text-decoration: underline;">/register</a>
            </div>
            <div class="line dim mt-2 text-center">
                <a href="/" class="blue text-decoration-none" style="text-decoration: underline;">cd ~</a>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginDto loginModel = new();
    private bool isLoading;
    private bool showError;

    private async Task HandleLogin()
    {
        isLoading = true;
        showError = false;

        var result = await AuthService.LoginAsync(loginModel);

        if (result)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            showError = true;
            isLoading = false;
        }
    }
}
