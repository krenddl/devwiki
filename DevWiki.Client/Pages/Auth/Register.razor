@page "/register"
@using DevWiki.Client.Models
@using DevWiki.Client.Services
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Регистрация - DevWiki</PageTitle>

<div class="terminal-window">
    <div class="terminal-header">
        <div class="term-dots">
            <div class="term-dot dot-close"></div>
            <div class="term-dot dot-min"></div>
            <div class="term-dot dot-max"></div>
        </div>
        register — DevWiki-Blazor-WASM (tty3)
    </div>
    
    <div class="terminal-body" style="display: flex; flex-direction: column; justify-content: center; align-items: center;">
        
        <div class="ascii-art text-center mb-4">
            <pre style="margin:0; background:transparent; border:none; padding:0; overflow:hidden; font-family:inherit;">
                     _     _            
                    (_)   | |           
  _ __ ___  __ _ _   _ ___| |_ ___ _ __ 
 | '__/ _ \/ _` | | | / __| __/ _ \ '__|
 | | |  __/ (_| | |_| \__ \ ||  __/ |   
 |_|  \___|\__, |\__, |___/\__\___|_|   
            __/ | __/ |                 
           |___/ |___/                  
            </pre>
        </div>

        <div class="term-form-container">
            <div class="line dim mb-4 text-center">Create a new user profile.</div>

            @if (showError)
            {
                <div class="line error mb-3">[System] Error: Ошибка при регистрации. Возможно, логин занят.</div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <div class="line">Username:</div>
                    <InputText id="username" class="term-input" autocomplete="off" spellcheck="false" @bind-Value="registerModel.Username" />
                    <ValidationMessage For="@(() => registerModel.Username)" class="error mt-1" style="font-size: 0.85rem;" />
                </div>

                <div class="mb-3">
                    <div class="line">Password:</div>
                    <InputText type="password" id="password" class="term-input" autocomplete="off" @bind-Value="registerModel.Password" />
                    <ValidationMessage For="@(() => registerModel.Password)" class="error mt-1" style="font-size: 0.85rem;" />
                </div>

                <div class="mb-3">
                    <div class="line">Confirm Password:</div>
                    <InputText type="password" id="confirmPassword" class="term-input" autocomplete="off" @bind-Value="registerModel.ConfirmPassword" />
                    <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="error mt-1" style="font-size: 0.85rem;" />
                </div>

                <button type="submit" class="term-btn" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>[Processing...]</span>
                    }
                    else
                    {
                        <span>> EXECUTE REGISTRATION</span>
                    }
                </button>
            </EditForm>
            
            <div class="line dim mt-4 text-center">
                Already have an account? <a href="/login" class="blue text-decoration-none" style="text-decoration: underline;">/login</a>
            </div>
            <div class="line dim mt-2 text-center">
                <a href="/" class="blue text-decoration-none" style="text-decoration: underline;">cd ~</a>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterDto registerModel = new();
    private bool isLoading;
    private bool showError;

    private async Task HandleRegister()
    {
        isLoading = true;
        showError = false;

        var result = await AuthService.RegisterAsync(registerModel);

        if (result)
        {
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            showError = true;
            isLoading = false;
        }
    }
}
