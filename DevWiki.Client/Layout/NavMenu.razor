@inject DevWiki.Client.Services.IAuthService AuthService
@inject NavigationManager NavigationManager

<nav class="top-navbar">
    <div class="d-flex align-items-center w-100 max-width-container mx-auto">
        <a class="text-white fw-bold d-flex align-items-center me-4" href="" style="font-size: 1.25rem; letter-spacing: -0.5px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
            DevWiki
        </a>

        <div class="d-flex flex-grow-1 align-items-center">
            <NavLink class="nav-link-custom mx-3" href="" Match="NavLinkMatch.All">Главная</NavLink>
        </div>

        <div class="d-flex align-items-center gap-3">
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted small">@context.User.Identity?.Name</span>
                    <button class="btn-modern btn-secondary-modern" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;" @onclick="Logout">
                        Выйти
                    </button>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="nav-link-custom" href="login">Войти</NavLink>
                    <NavLink class="btn-modern btn-primary-modern" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;" href="register">Регистрация</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

@code {
    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }
}
